# ─── Google OAuth 2.0 (Calendar API) ───────────────────────────────
# Obtidos do Google Cloud Console (substitua pelos seus valores)
GOOGLE_CLIENT_ID=seu-client-id.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=seu-client-secret
GOOGLE_PROJECT_ID=seu-project-id

# O refresh token é obtido na primeira autenticação OAuth
# O access token é efêmero; se expirar, o refresh token gera um novo automaticamente
GOOGLE_REFRESH_TOKEN=seu-refresh-token
GOOGLE_ACCESS_TOKEN=seu-access-token-inicial

# Endpoints Google (valores padrão)
GOOGLE_TOKEN_URI=https://oauth2.googleapis.com/token
GOOGLE_AUTH_URI=https://accounts.google.com/o/oauth2/auth
GOOGLE_REDIRECT_URI=http://localhost

# Caminho opcional para persistir o token renovado entre execuções
GOOGLE_TOKEN_PATH=token.json

# ─── Áudio (Docker / PulseAudio) ────────────────────────────────────
# Necessário apenas no Docker em host Linux. No macOS, rode direto: python main.py
# PULSE_SERVER=unix:/run/user/1000/pulse/native

# ─── OpenAI ────────────────────────────────────────────────────────
OPENAI_API_KEY=sk-seu-api-key
OPENAI_TEXT_MODEL=gpt-5.6-luna

# ─── TTS (síntese de voz) ──────────────────────────────────────────
TTS_MODEL=gpt-4o-mini-tts
TTS_VOICE=nova
